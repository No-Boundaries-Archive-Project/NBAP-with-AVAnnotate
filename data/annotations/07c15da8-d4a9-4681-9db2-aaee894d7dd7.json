      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "It's something like that, yeah."
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "_uncategorized_",
          "tag": "Brenda Dixon Gottschild"
        }
